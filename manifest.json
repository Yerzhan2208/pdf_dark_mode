{
  "manifest_version": 3,
  "name": "PDF Dark Mode",
  "version": "1.0",
  "description": "Inverts colors on PDF viewers for a dark mode experience.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}